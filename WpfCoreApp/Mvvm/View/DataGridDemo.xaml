<Window x:Class="WpfCoreApp.Mvvm.View.DataGridDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCoreApp.Mvvm.View"
        mc:Ignorable="d"
        Title="DataGridDemo" Height="450" Width="800"
        xmlns:vm="clr-namespace:WpfCoreApp.Mvvm.ViewModel">

    <Window.DataContext>
        <vm:EmployeeVM/>
    </Window.DataContext>

    <Grid>
        <!-- Define two rows: one for DataGrid, one for Button -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- Flexible space for DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Auto size for Button -->
        </Grid.RowDefinitions>

        <!-- DataGrid in first row -->
        <!--<DataGrid Grid.Row="0" AutoGenerateColumns="True" />-->
        <DataGrid x:Name="dgEmployees" Grid.Row="0" ItemsSource="{Binding Employees}" AutoGenerateColumns="False"  Margin="0,-1,0,5" 
                  SelectionMode="Single" SelectionChanged="dgEmployees_SelectionChanged" RowEditEnding="dgEmployees_RowEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" MinWidth="100" Width="auto">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Department" Binding="{Binding Department}" MinWidth="100" Width="auto">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Age" Binding="{Binding Age}" MinWidth="50" Width="auto">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>

                </DataGridTextColumn>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="auto" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Save button in second row -->

        <Button x:Name="btnSave" Grid.Row="1" Content="Save" MinWidth="60" IsEnabled="{Binding HasChanges}"
                HorizontalAlignment="Left" Margin="260,10,0,10" Width="60" Click="btnSave_Click"/>
        <Button x:Name="btnCancel" Grid.Row="1" Content="Close" MinWidth="60" HorizontalAlignment="Left" 
                Margin="410,10,0,10" Click="btnCancel_Click"   />
        <Button x:Name="btnDelete" Content="Delete" MinWidth="60" HorizontalAlignment="Left" IsEnabled="False"
                Margin="335,0,0,0" Grid.Row="1" VerticalAlignment="Center" Click="btnDelete_Click"/>

    </Grid>
</Window>
