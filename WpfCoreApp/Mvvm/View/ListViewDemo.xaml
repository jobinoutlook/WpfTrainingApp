<Window x:Class="WpfCoreApp.Mvvm.View.ListViewDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCoreApp.Mvvm.View"
        mc:Ignorable="d"
        Title="ListViewDemo" Height="450" Width="800"
        xmlns:vm="clr-namespace:WpfCoreApp.Mvvm.ViewModel"
        xmlns:img="clr-namespace:WpfCoreApp.AppHelper">
    <Window.DataContext>
        <vm:CitizenVM/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Vector placeholder silhouette -->
        <DrawingImage x:Key="PlaceholderImage">
            <DrawingImage.Drawing>
                <GeometryDrawing Brush="Gray">
                    <!-- Circle for head -->
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="0,0" RadiusX="20" RadiusY="20"/>
                            <!-- Body shape -->
                            <EllipseGeometry Center="0,40" RadiusX="35" RadiusY="20"/>
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingImage.Drawing>
        </DrawingImage>
        <!-- Converter to turn byte[] into ImageSource -->
        <img:ByteArrayToImageConverter x:Key="ImageConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <!-- Flexible space for DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Auto size for Button -->
        </Grid.RowDefinitions>

        <ListView Grid.Row="0" ItemsSource="{Binding Citizens}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID"  DisplayMemberBinding="{Binding Id}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Id}" MinWidth="80"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="First Name" DisplayMemberBinding="{Binding FirstName}" />
                    <GridViewColumn Header="Last Name" DisplayMemberBinding="{Binding LastName}" />

                    <!-- Photo column using converter -->
                    <GridViewColumn Header="Photo">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Width="100" Height="50" MinWidth="50"
                                       Source="{Binding Photo, Converter={StaticResource ImageConverter}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Date of Birth"
                                    DisplayMemberBinding="{Binding DateOfBirth, StringFormat=d}" />
                    
                   
                    <!-- Button column -->
                    <GridViewColumn Header="Actions" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" >
                                    <Button Content="Update Photo" Margin="0,0,5,0" MinWidth="100"
                                            Command="{Binding DataContext.InsertPhotoCommand, 
                                            RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Edit" MinWidth="50"
                                        Command="{Binding DataContext.EditCitizenCommand, 
                                        RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}" />
                                    
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                </GridView>
            </ListView.View>
        </ListView>
        <Button x:Name="btnAddCitizen" Content="Add Citizen" MinWidth="60" HorizontalAlignment="Left"
         Margin="335,10,0,10" Grid.Row="1" VerticalAlignment="Center" Command="{Binding AddCitizenCommand}" />
    </Grid>
</Window>
